/**
 * Google Apps Script — Send Stanford acceptance letter to yourself
 *
 * HOW TO USE:
 * 1. Go to https://script.google.com and create a new project
 * 2. Paste this entire file into the editor
 * 3. Change STUDENT_NAME below to the character's name
 * 4. Click Run → sendAcceptanceLetter
 * 5. Authorize when prompted (needs Gmail access)
 * 6. Check your Gmail inbox / Drafts
 */

// ── Configure these ────────────────────────────────────────────────────────────
var STUDENT_NAME = "Alex Johnson";   // <-- change to the character's name
var RECIPIENT    = "you@example.com"; // <-- change to the target email address
var CREATE_DRAFT = false;            // false = send immediately, true = save as draft
// ───────────────────────────────────────────────────────────────────────────────

function sendAcceptanceLetter() {
  var recipient = RECIPIENT;
  var subject   = "Stanford University — Your Admission Decision";
  var html      = getHtmlBody().replace(/\[Student Name\]/g, STUDENT_NAME);

  if (CREATE_DRAFT) {
    GmailApp.createDraft(recipient, subject, "", { htmlBody: html });
    Logger.log("Draft created. Check your Gmail Drafts folder.");
  } else {
    GmailApp.sendEmail(recipient, subject, "", { htmlBody: html });
    Logger.log("Email sent to: " + recipient);
  }
}

